# Required
NEXT_PUBLIC_GTM_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_POSTHOG_KEY="phc_XXXXXXXXXX"

# Optional - Tally.so feedback form (leave empty to disable)
NEXT_PUBLIC_TALLY_FORM_ID=""

# Required - Supabase (anonymous auth + rate limiting)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Required - OpenAI-compatible LLM (used for AI post generation)
LLM_API_KEY="sk-..."
# Optional - defaults to gpt-4o-mini
LLM_MODEL=""

# Optional - LinkedIn publishing & scheduling (Wave 4). Leave blank to keep the
# integration inert. Create an app at https://www.linkedin.com/developers/apps and
# add the "Sign In with LinkedIn using OpenID Connect" and "Share on LinkedIn" products.
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
# Optional - defaults to <site.url>/api/linkedin/callback. Must exactly match an
# "Authorized redirect URL" registered on the LinkedIn app.
LINKEDIN_REDIRECT_URI=""
# 64-char hex (32 bytes) AES-256-GCM key for encrypting tokens at rest.
# Generate with: openssl rand -hex 32
LINKEDIN_TOKEN_ENC_KEY=""
# Shared secret for the Vercel Cron publisher. Generate with: openssl rand -hex 16
CRON_SECRET=""
# Supabase service-role key (Project Settings > API). Required for the cron publisher
# AND for LinkedIn login (resolving which account owns a LinkedIn identity and
# switching the session into it). Without it, LinkedIn connect falls back to
# attach-only and cannot sign returning users back into their existing account.
SUPABASE_SERVICE_ROLE_KEY=""
